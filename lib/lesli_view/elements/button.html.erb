

<% if mode == :button_to %>

    <%= button_to(
        @url,
        method: @method,
        params: @params,
        disabled: disabled?,
        **common_attributes
    ) do %>
        <%= button_content %>
    <% end %>

<% elsif mode == :link %>

    <% if disabled? %>
        <%= content_tag(:span, role: "link", tabindex: -1, **common_attributes) do %>
            <%= button_content %>
        <% end %>
    <% else %>
        <%= link_to(@url, **common_attributes) do %>
            <%= button_content %>
        <% end %>
    <% end %>

<% else %>

    <%= content_tag(
        :button,
        type: button_type,
        disabled: disabled?,
        **common_attributes
    ) do %>
        <%= button_content %>
    <% end %>

<% end %>
